{
  "id": "montenisa",
  "schemaVersion": "2.0.0",
  "locales": ["it"],
  "defaultLocale": "it",
  "pages": [
    {
      "key": "home",
      "route": "/",
      "label": "Home",
      "sections": [
        {
          "kind": "group",
          "key": "brand",
          "label": "Brand",
          "fields": {
            "name": { "kind": "text", "label": "Nome brand", "required": true, "maxLength": 80 },
            "mark": { "kind": "text", "label": "Monogramma", "maxLength": 20 }
          }
        },
        {
          "kind": "group",
          "key": "hero",
          "label": "Hero",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "secondaryEyebrow": { "kind": "text", "label": "Eyebrow secondaria", "maxLength": 60 },
            "scrollLabel": { "kind": "text", "label": "Label scroll", "maxLength": 24 },
            "headline": { "kind": "text", "label": "Titolo hero", "required": true, "maxLength": 90, "ai": { "purpose": "headline", "tone": "luxury" } },
            "subtitle": { "kind": "text", "label": "Sottotitolo hero", "maxLength": 120 },
            "body": { "kind": "richText", "label": "Testo hero", "ai": { "purpose": "bodyCopy", "tone": "luxury" } },
            "image": { "kind": "image", "label": "Immagine hero" }
          }
        },
        {
          "kind": "group",
          "key": "introduction",
          "label": "La tenuta",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "headline": { "kind": "text", "label": "Titolo", "required": true, "maxLength": 90 },
            "body": { "kind": "richText", "label": "Testo" },
            "cta": { "kind": "text", "label": "CTA", "maxLength": 80 },
            "image": { "kind": "image", "label": "Immagine tenuta" }
          }
        },
        {
          "kind": "group",
          "key": "product",
          "label": "Prodotto",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "headline": { "kind": "text", "label": "Titolo", "required": true, "maxLength": 90 },
            "body": { "kind": "richText", "label": "Testo" },
            "image": { "kind": "image", "label": "Immagine prodotto" }
          }
        },
        {
          "kind": "list",
          "key": "product.slides",
          "label": "Slide prodotto",
          "itemActions": "editOnly",
          "item": {
            "headline": { "kind": "text", "label": "Titolo slide", "required": true, "maxLength": 80 },
            "image": { "kind": "image", "label": "Immagine slide" },
            "thumbnail": { "kind": "image", "label": "Miniatura slide" }
          }
        },
        {
          "kind": "group",
          "key": "archive",
          "label": "Curtes Francae",
          "fields": {
            "cta": { "kind": "text", "label": "CTA archivio", "maxLength": 90 }
          }
        },
        {
          "kind": "list",
          "key": "archive.states",
          "label": "Stati archivio",
          "itemActions": "editOnly",
          "item": {
            "headline": { "kind": "text", "label": "Titolo stato", "required": true, "maxLength": 80 },
            "body": { "kind": "richText", "label": "Testo stato" }
          }
        },
        {
          "kind": "group",
          "key": "vineyard",
          "label": "Vigna",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "headline": { "kind": "text", "label": "Titolo", "required": true, "maxLength": 90 },
            "body": { "kind": "richText", "label": "Testo" },
            "image": { "kind": "image", "label": "Immagine vigna" }
          }
        },
        {
          "kind": "group",
          "key": "cellar",
          "label": "Cantina",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "cta": { "kind": "text", "label": "CTA cantina", "maxLength": 80 }
          }
        },
        {
          "kind": "list",
          "key": "cellar.states",
          "label": "Stati cantina",
          "itemActions": "editOnly",
          "item": {
            "headline": { "kind": "text", "label": "Titolo stato", "required": true, "maxLength": 80 },
            "body": { "kind": "richText", "label": "Testo stato" }
          }
        },
        {
          "kind": "group",
          "key": "memory",
          "label": "Memoria",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "headline": { "kind": "text", "label": "Titolo", "required": true, "maxLength": 90 }
          }
        },
        {
          "kind": "list",
          "key": "memory.items",
          "label": "Elementi memoria",
          "itemActions": "editOnly",
          "item": {
            "number": { "kind": "text", "label": "Numero", "maxLength": 8 },
            "headline": { "kind": "text", "label": "Titolo", "required": true, "maxLength": 80 },
            "body": { "kind": "richText", "label": "Testo" }
          }
        },
        {
          "kind": "group",
          "key": "contact",
          "label": "Contatti",
          "fields": {
            "eyebrow": { "kind": "text", "label": "Eyebrow", "maxLength": 60 },
            "title": { "kind": "text", "label": "Titolo", "required": true, "maxLength": 80 },
            "email": { "kind": "text", "label": "Email", "maxLength": 80 },
            "location": { "kind": "text", "label": "Luogo", "maxLength": 120 },
            "legal": { "kind": "text", "label": "Legal", "maxLength": 160 }
          }
        },
        {
          "kind": "list",
          "key": "navigation",
          "label": "Navigazione",
          "itemActions": "editOnly",
          "item": {
            "label": { "kind": "text", "label": "Label", "required": true, "maxLength": 40 },
            "href": { "kind": "text", "label": "Ancora", "required": true, "maxLength": 40 }
          }
        }
      ]
    }
  ]
}
