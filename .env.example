# Server-side endpoint returning the Montenisa landing page JSON from Shutter.
# The response can override any subset of src/lib/shutter.ts LandingContent.
SHUTTER_CONTENT_ENDPOINT=

# Optional alias if the M77 Shutter platform exposes a page-specific endpoint.
SHUTTER_LANDING_ENDPOINT=

# Comma-separated HTTPS hostnames used by Shutter-hosted images.
# Example: assets.shutter.m77.dev,cdn.example.com
SHUTTER_IMAGE_HOSTNAMES=
